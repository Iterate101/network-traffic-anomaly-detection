# Python 运行环境
.venv/
__pycache__/
*.pyc
.pytest_cache/

# 真实数据集通常很大，不放进 Git 仓库，只保留 data 目录占位文件
data/**
!data/
!data/.gitkeep
data.zip
*.parquet

# 实验输出可以随时重新生成
results/**
!results/
!results/.gitkeep

# PPT 文件和本地演示工作区不上传 GitHub
presentation_workspace/**
*.ppt
*.pptx

# 论文 PDF 仅用于本地课程分享，不上传仓库
papers/**
